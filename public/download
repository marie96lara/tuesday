<!-- STITCH_THREEJS_START:ANIMATION_4 class="w-[500px] h-[500px] mx-auto bg-transparent" -->
<div class="w-[500px] h-[500px] mx-auto bg-transparent" style="display:block;">
<script src="https://ajax.googleapis.com/ajax/libs/threejs/r125/three.min.js"></script>
<div id="threejs-container-ANIMATION_4" style="width:100%;height:100%"></div>
<script>
(function() {
  const container = document.getElementById('threejs-container-ANIMATION_4');
  const devicePixelRatio = window.devicePixelRatio || 1;
  
const scene = new THREE.Scene();
const width = container.clientWidth || window.innerWidth;
const height = container.clientHeight || window.innerHeight;
const camera = new THREE.PerspectiveCamera(75, width / height, 0.1, 1000);
const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
renderer.setSize(width, height);
renderer.setPixelRatio(window.devicePixelRatio);
container.appendChild(renderer.domElement);

// Lighting
const ambientLight = new THREE.AmbientLight(0x00a3ff, 0.5);
scene.add(ambientLight);
const pointLight = new THREE.PointLight(0x00a3ff, 2, 50);
pointLight.position.set(5, 5, 5);
scene.add(pointLight);

// Group to hold everything
const orbGroup = new THREE.Group();
scene.add(orbGroup);

// Inner Core Glow (Shader-like Material)
const coreGeometry = new THREE.SphereGeometry(1.5, 32, 32);
const coreMaterial = new THREE.MeshPhongMaterial({
    color: 0x00a3ff,
    emissive: 0x00a3ff,
    emissiveIntensity: 2,
    transparent: true,
    opacity: 0.8
});
const core = new THREE.Mesh(coreGeometry, coreMaterial);
orbGroup.add(core);

// Wireframe Globe
const wireframeGeometry = new THREE.SphereGeometry(2.5, 32, 32);
const wireframeMaterial = new THREE.MeshBasicMaterial({
    color: 0x00a3ff,
    wireframe: true,
    transparent: true,
    opacity: 0.3
});
const wireframe = new THREE.Mesh(wireframeGeometry, wireframeMaterial);
orbGroup.add(wireframe);

// Particles / Points
const pointsGeometry = new THREE.BufferGeometry();
const pointsCount = 1000;
const coords = new Float32Array(pointsCount * 3);
for (let i = 0; i < pointsCount; i++) {
    const r = 2.5 + Math.random() * 0.5;
    const theta = Math.random() * Math.PI * 2;
    const phi = Math.acos(2 * Math.random() - 1);
    coords[i * 3] = r * Math.sin(phi) * Math.cos(theta);
    coords[i * 3 + 1] = r * Math.sin(phi) * Math.sin(theta);
    coords[i * 3 + 2] = r * Math.cos(phi);
}
pointsGeometry.setAttribute('position', new THREE.BufferAttribute(coords, 3));
const pointsMaterial = new THREE.PointsMaterial({
    color: 0x00ffff,
    size: 0.05,
    transparent: true,
    opacity: 0.8
});
const points = new THREE.Points(pointsGeometry, pointsMaterial);
orbGroup.add(points);

camera.position.z = 8;

// Mouse Tracking
let mouseX = 0, mouseY = 0;
window.addEventListener('mousemove', (e) => {
    mouseX = (e.clientX / window.innerWidth - 0.5) * 2;
    mouseY = (e.clientY / window.innerHeight - 0.5) * 2;
});

// Animation Loop
function animate() {
    requestAnimationFrame(animate);
    
    // Smooth rotations
    orbGroup.rotation.y += 0.005;
    wireframe.rotation.x += 0.002;
    points.rotation.y -= 0.001;
    
    // Dynamic core pulse
    const time = Date.now() * 0.001;
    core.scale.setScalar(1 + Math.sin(time * 2) * 0.05);
    coreMaterial.emissiveIntensity = 1.5 + Math.sin(time * 3) * 0.5;
    
    // Gentle mouse influence
    orbGroup.rotation.x += (mouseY * 0.2 - orbGroup.rotation.x) * 0.05;
    orbGroup.rotation.y += (mouseX * 0.2 - orbGroup.rotation.y) * 0.05;
    
    renderer.render(scene, camera);
}

window.addEventListener('resize', () => {
    const w = container.clientWidth || window.innerWidth;
    const h = container.clientHeight || window.innerHeight;
    camera.aspect = w / h;
    camera.updateProjectionMatrix();
    renderer.setSize(w, h);
});

animate();

})();
</script>
